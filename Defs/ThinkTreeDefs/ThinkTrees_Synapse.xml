<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <ThinkTreeDef>
    <defName>Synapse_MentalStatesCritical</defName>
    <insertTag>MentalStateCritical</insertTag>
    <insertPriority>100</insertPriority>
    <thinkRoot Class="ThinkNode_Priority">
      <subNodes>
        
        <!-- Homicidal -->
        <li Class="ThinkNode_ConditionalMentalState">
          <state>Synapse_MentalState_Homicidal</state>
          <subNodes>
            <li Class="RimSynapse.Psychology.MentalStates.JobGiver_Homicidal" />
          </subNodes>
        </li>

        <!-- Suicidal: Antagonize -->
        <li Class="ThinkNode_ConditionalMentalState">
          <state>Synapse_SuicidalAntagonize</state>
          <subNodes>
            <li Class="RimSynapse.Psychology.MentalStates.JobGiver_SuicidalAntagonize" />
          </subNodes>
        </li>

        <!-- Euphoric: Reckless -->
        <li Class="ThinkNode_ConditionalMentalState">
          <state>Synapse_EuphoricReckless</state>
          <subNodes>
            <li Class="RimSynapse.Psychology.MentalStates.JobGiver_EuphoricReckless" />
          </subNodes>
        </li>

        <!-- Suicidal: Burn -->
        <li Class="ThinkNode_ConditionalMentalState">
          <state>Synapse_SuicidalBurn</state>
          <subNodes>
            <li Class="RimSynapse.Psychology.MentalStates.JobGiver_SuicidalBurn" />
          </subNodes>
        </li>

        <!-- Suicidal: Starve -->
        <li Class="ThinkNode_ConditionalMentalState">
          <state>Synapse_SuicidalStarve</state>
          <subNodes>
            <!-- Do NOT eat! But allow sleeping -->
            <li Class="JobGiver_GetRest"/>
            
            <!-- Force them to do their normal work routine despite being in a mental state! -->
            <li Class="ThinkNode_Subtree">
              <treeDef>MainColonistBehaviorCore</treeDef>
            </li>
            
            <!-- Fallback if they can't work or sleep, just wander aimlessly instead of breaking AI -->
            <li Class="JobGiver_WanderAnywhere">
              <maxDanger>Deadly</maxDanger>
            </li>
          </subNodes>
        </li>

      </subNodes>
    </thinkRoot>
  </ThinkTreeDef>
</Defs>
